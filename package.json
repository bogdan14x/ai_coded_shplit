{
	"name": "shibasplit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"d1:migrate": "wrangler d1 execute shibasplit --local --file ./drizzle/0001_*.sql",
		"d1:create": "wrangler d1 create shibasplit",
		"d1:seed": "tsx scripts/seed-d1.ts",
		"db:generate": "drizzle-kit generate --config drizzle.config.d1.ts",
		"db:push": "drizzle-kit push --config drizzle.config.d1.ts"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/better-sqlite3": "^7.6.13",
		"@vitest/browser": "^4.1.0",
		"@vitest/browser-playwright": "^4.1.0",
		"autoprefixer": "^10.4.27",
		"drizzle-kit": "^0.31.9",
		"jsdom": "^27.0.1",
		"nanoid": "^5.1.6",
		"postcss": "^8.5.8",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"drizzle-orm": "^0.45.1"
	}
}
